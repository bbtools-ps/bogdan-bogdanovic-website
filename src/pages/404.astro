---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslatedPath } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);

const content = {
  en: {
    title: "Page not found",
    eyebrow: "404",
    heading: "This page does not exist.",
    description:
      "The link may be outdated, or the page may have been moved to a different address.",
    homeLabel: "Go to homepage",
  },
  sr: {
    title: "Stranica nije pronađena",
    eyebrow: "404",
    heading: "Ova stranica ne postoji.",
    description:
      "Link je možda zastareo ili je stranica premeštena na drugu adresu.",
    homeLabel: "Idi na početnu stranicu",
  },
} as const;

const page = content[lang];
---

<BaseLayout title={`${page.title} | Bogdan Bogdanovic`}>
  <section class="my-1 flex flex-1 items-center justify-center">
    <div class="max-w-2xl text-center">
      <p
        class="mb-4 text-sm font-semibold tracking-[0.35em] text-slate-600 uppercase dark:text-slate-300"
      >
        {page.eyebrow}
      </p>
      <h1>{page.heading}</h1>
      <p
        class="mx-auto mb-10 max-w-xl text-lg text-slate-700 dark:text-slate-200"
      >
        {page.description}
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={translatePath("/")} class="button-link">{page.homeLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
