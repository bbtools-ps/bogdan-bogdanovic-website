---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const t = useTranslations(lang);
---

<BaseLayout title={`${t("notFound.title")} | Bogdan Bogdanovic`}>
  <section class="my-1 flex flex-1 items-center justify-center">
    <div class="max-w-2xl text-center">
      <p
        class="mb-4 text-sm font-semibold tracking-[0.35em] text-slate-600 uppercase dark:text-slate-300"
      >
        {t("notFound.eyebrow")}
      </p>
      <h1>{t("notFound.heading")}</h1>
      <p
        class="mx-auto mb-10 max-w-xl text-lg text-slate-700 dark:text-slate-200"
      >
        {t("notFound.description")}
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={translatePath("/")} class="button-link">
          {t("notFound.homeLabel")}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
